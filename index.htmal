    const { useState, useEffect, useRef } = React;

    // ============================================================================
    // 🔴 1. AAPKI GOOGLE MAPS API KEY 🔴
    const GOOGLE_MAPS_API_KEY = "AIzaSyC_uP3i3qFk31xZfY6br09DI-LjA60aC_c"; 

    // 🔴 2. FIREBASE DATABASE KEYS 🔴
    // Asli location share karne ke liye yahan apne Firebase Project ki keys zaroor dalein
    const firebaseConfig = {
      // apiKey: "AIza...",
